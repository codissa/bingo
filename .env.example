# Copy this file to .env and fill in the values.
# In Vercel, add each of these as Environment Variables (Project Settings -> Environment Variables).
# All VITE_ vars are exposed to the browser at build time, so do NOT put real secrets here.

# --- Firebase web app config (Project settings -> General -> Your apps -> SDK setup) ---
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# --- Admin gate (simple password for the /admin screen) ---
VITE_ADMIN_PASSWORD=changeme
